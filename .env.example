# Database (Neon PostgreSQL connection string)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Paystack (get keys from https://dashboard.paystack.com)
PAYSTACK_SECRET_KEY=sk_live_xxxx
PAYSTACK_BASE_URL=https://api.paystack.co

# Where the frontend runs (used for payment success redirect)
# Local: http://localhost:5173  |  Production: https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# Server port (optional, default 8000)
PORT=8000

# Resend (https://resend.com) — subscription confirmation email
# Get API key from https://resend.com/api-keys. If unset, confirmation is only logged.
RESEND_API_KEY=re_xxxx
# Sender address (must be a verified domain in Resend, or use onboarding@resend.dev for testing)
EMAIL_FROM=RepeatOS <onboarding@resend.dev>
